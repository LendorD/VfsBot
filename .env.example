# ============================================================
# Пример файла переменных окружения.
# Скопируйте в `.env` и заполните реальными значениями:
#     cp .env.example .env
# ============================================================

# --- Telegram ---
# Токен бота, выданный @BotFather
BOT_TOKEN=123456789:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# --- База данных PostgreSQL ---
# Строка подключения в формате asyncpg
DATABASE_URL=postgresql+asyncpg://vfs_user:vfs_password@localhost:5432/vfs_bot

# --- VFS Global ---
# Базовый URL сайта VFS (зависит от страны/визового центра)
VFS_BASE_URL=https://visa.vfsglobal.com
# Логин и пароль личного кабинета VFS (если требуется авторизация)
VFS_LOGIN=user@example.com
VFS_PASSWORD=change_me

# Критерии записи (что выбирать в списках шага 1). Текст как на сайте,
# можно часть. Пусто = скрипт просто покажет доступные варианты.
VFS_CENTER=
VFS_CATEGORY=
VFS_SUBCATEGORY=

# --- Планировщик ---
# Интервал проверки свободных слотов в секундах
CHECK_INTERVAL_SECONDS=300

# --- Браузер ---
# Запускать ли браузер в headless-режиме (true/false)
BROWSER_HEADLESS=true
# Таймаут ожидания элементов страницы, мс
BROWSER_TIMEOUT_MS=30000

# --- Прокси (опционально) ---
# Помогает обойти блокировку VFS по IP (ошибка 403201). Лучше резидентный.
# Формат: http://host:port  или  socks5://host:port . Пусто = без прокси.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# --- Капча ---
# Ключ внешнего сервиса решения капчи (опционально, для будущей интеграции)
CAPTCHA_API_KEY=

# --- Сессии браузера ---
# Каталог для хранения сохранённых сессий (cookies/localStorage)
SESSION_STORAGE_PATH=sessions
# Срок жизни сохранённой сессии в часах (после — считается устаревшей)
SESSION_MAX_AGE_HOURS=24

# --- Логирование ---
# Уровень логирования: TRACE, DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Путь к файлу логов
LOG_FILE=logs/bot.log
